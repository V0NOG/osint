# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Ingestion — ACLED conflict data ──────────────────────────────────────────
# Register free at https://acleddata.com/register/
# Uses OAuth — email + password, no static API key needed
ACLED_EMAIL=
ACLED_PASSWORD=

# ─── Ingestion — API protection ───────────────────────────────────────────────
# Protects POST /api/ingest — set to any secret string
# Usage: Authorization: Bearer <your-secret>
INGEST_API_KEY=

# ─── Vercel Cron protection ───────────────────────────────────────────────────
# Vercel automatically sends this as: Authorization: Bearer <CRON_SECRET>
# Set in Vercel dashboard under Environment Variables
CRON_SECRET=
